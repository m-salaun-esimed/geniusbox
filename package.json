{
  "name": "smart10",
  "version": "0.1.0",
  "description": "Smart10-style local multiplayer desktop game",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev:web": "vite --host",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "build:web": "tsc --noEmit && vite build",
    "build:electron": "tsc -p tsconfig.electron.json && node -e \"require('node:fs').copyFileSync('desktop/electron/preload.cjs','dist-electron/preload.cjs')\"",
    "cap:add:android": "npx cap add android",
    "cap:sync:android": "npx cap sync android",
    "build:apk": "npm run build:web && npm run cap:sync:android && cd android && ./gradlew assembleDebug",
    "build": "npm run build:web && npm run build:electron",
    "build:all": "npm run build && npm run build:apk",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "dist": "npm run build && electron-builder"
  },
  "keywords": [
    "smart10",
    "electron",
    "capacitor",
    "react",
    "multiplayer"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.smart10.desktop",
    "productName": "Smart10 Local",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build-resources"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.games"
    },
    "win": {
      "target": "nsis",
      "icon": "build-resources/icons/app-icon.jpg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
